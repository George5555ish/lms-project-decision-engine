# MongoDB connection (required) - use same DB as LMS backend or a dedicated database
MONGODB_URI=your_mongodb_connection_string
MONGODB_DB_NAME=lmsDB

# Port (Railway sets PORT automatically)
PORT=4000

# Optional: use separate env vars if running alongside LMS backend
# DECISION_ENGINE_PORT=4000
# DECISION_ENGINE_MONGO_URI=mongodb+srv://...
# DECISION_ENGINE_DB_NAME=lmsDB
